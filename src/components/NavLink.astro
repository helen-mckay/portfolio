---
// check current path
const pathname = new URL(Astro.request.url).pathname;
const { href, name } = Astro.props;

const classes = "uppercase tracking-wider text-base/normal sm:text-lg/normal";
---

<a href={href} class={classes + " " + (pathname === href ? "active" : "inactive")}>{name}</a>

<style>
    .active {
        color: var(--color-zinc-50);
        border-bottom: 1px solid var(--color-zinc-50);
    }

    .inactive {
        color: var(--color-zinc-300);
    }
</style>