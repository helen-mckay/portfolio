---
// check current path
const pathname = Astro.url.pathname;
const { href, name } = Astro.props;

const classes = "navlink uppercase tracking-wider text-base/normal sm:text-lg/normal";

const linkStatus = () => {
    if (pathname === href)
    {
        return ("active");
    }
    else if (pathname === (href + "/"))
    {
        return "active";
    }
    else
    {
        return "inactive";
    }
}
---

<a href={href} class={classes + " " + (linkStatus())}>{name}</a>

<style>
    .active {
        color: var(--color-zinc-50);
        border-bottom: 1px solid var(--color-zinc-50);
    }

    .inactive {
        color: var(--color-zinc-300);
        transition: color ease 0.2s;
    }

    .inactive:hover {
        color: var(--color-zinc-50);
    }
</style>